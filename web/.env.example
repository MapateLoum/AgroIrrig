# MongoDB Atlas — chaîne de connexion complète (avec nom de base à la fin)
# Exemple : mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/agroirrig?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/agroirrig?retryWrites=true&w=majority"

# NextAuth — générer un secret avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="change-moi-en-secret-aleatoire"
NEXTAUTH_URL="http://localhost:3000"

# URL du micro-service Python (FastAPI) qui sert le modèle XGBoost
ML_SERVICE_URL="http://localhost:8000"

# Gmail SMTP — pour l'envoi des codes OTP (vérification email + reset mot de passe)
# GMAIL_USER : ton adresse Gmail complète
# GMAIL_APP_PASSWORD : un "mot de passe d'application" (PAS ton mot de passe Gmail normal)
#   1. Active la validation en 2 étapes sur ton compte Google
#   2. Va sur https://myaccount.google.com/apppasswords
#   3. Crée un mot de passe d'application (nom libre, ex: "AgroIrrig")
#   4. Colle le code généré (16 caractères, sans espaces) ci-dessous
GMAIL_USER="ton-adresse@gmail.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
